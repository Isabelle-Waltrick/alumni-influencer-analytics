# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
# React dev server — CORS + verify/reset links in emails (see emailService.js)
CLIENT_ORIGIN=http://localhost:5173

# Timezone — must be UTC so cron jobs (midnight, 6PM) are consistent across environments
TZ=UTC

# MongoDB
MONGO_URI=mongodb://localhost:27017/ar_alumni

# Allowed registration email domain (CW1 brief: "university domain required")
# Only emails ending in @<this-domain> can register. Default: westminster.ac.uk.
ALLOWED_EMAIL_DOMAIN=westminster.ac.uk
# Preferred: comma-separated list of allowed domains.
# If set, this overrides ALLOWED_EMAIL_DOMAIN.
ALLOWED_EMAIL_DOMAINS=westminster.ac.uk,my.westminster.ac.uk

# Session
SESSION_SECRET=replace_this_with_a_long_random_string
# Enable CSRF middleware on session endpoints (recommended true for production/demo)
ENABLE_CSRF=true

# Rate limiting
# Max requests per minute per API key on the public endpoint (default: 100)
API_KEY_RATE_LIMIT=100

# Auth rate limiting (login/register/forgot/reset only)
# Default: 15 minutes window, max 20 in production / 200 in development
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=200

# Email (use Mailtrap for dev)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=587
EMAIL_USER=your_mailtrap_user
EMAIL_PASS=your_mailtrap_pass
EMAIL_FROM=noreply@westminster.ac.uk
