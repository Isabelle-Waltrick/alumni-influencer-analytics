<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' | Alumni Bidding' : 'Alumni Bidding' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <style>
    body { background: #f8f9fa; }
    .card { border: none; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
    .section-card { margin-bottom: 1.5rem; }
    .toast-container { position: fixed; top: 1rem; right: 1rem; z-index: 9999; }
    .badge-complete { background: #198754; }
    .completion-bar { height: 10px; border-radius: 5px; }
  </style>
</head>
<body>
<script>
  let __csrfState = null;
  async function __getCsrfHeaders() {
    if (__csrfState && !__csrfState.enabled) return {};
    if (__csrfState && __csrfState.enabled && __csrfState.token) {
      return { 'x-csrf-token': __csrfState.token };
    }
    const r = await fetch('/api/csrf-token', { credentials: 'include' });
    const d = await r.json();
    if (!d.csrfEnabled) {
      __csrfState = { enabled: false };
      return {};
    }
    __csrfState = { enabled: true, token: d.csrfToken || '' };
    return { 'x-csrf-token': __csrfState.token };
  }
  async function __jsonHeaders() {
    const csrf = await __getCsrfHeaders();
    return { 'Content-Type': 'application/json', ...csrf };
  }
  // shared fetch helpers — CSRF headers added when server has ENABLE_CSRF=true
  const api = {
    async get(url) {
      const r = await fetch(url, { credentials: 'include' });
      return r.json();
    },
    async post(url, body) {
      const r = await fetch(url, {
        method: 'POST',
        headers: await __jsonHeaders(),
        credentials: 'include',
        body: JSON.stringify(body),
      });
      return { status: r.status, data: await r.json() };
    },
    async put(url, body) {
      const r = await fetch(url, {
        method: 'PUT',
        headers: await __jsonHeaders(),
        credentials: 'include',
        body: JSON.stringify(body),
      });
      return { status: r.status, data: await r.json() };
    },
    async patch(url, body) {
      const r = await fetch(url, {
        method: 'PATCH',
        headers: await __jsonHeaders(),
        credentials: 'include',
        body: JSON.stringify(body),
      });
      return { status: r.status, data: await r.json() };
    },
    async del(url) {
      const r = await fetch(url, {
        method: 'DELETE',
        headers: await __getCsrfHeaders(),
        credentials: 'include',
      });
      return { status: r.status, data: await r.json() };
    },
    async postForm(url, formData) {
      const r = await fetch(url, {
        method: 'POST',
        headers: await __getCsrfHeaders(),
        credentials: 'include',
        body: formData,
      });
      return { status: r.status, data: await r.json() };
    },
  };
</script>
