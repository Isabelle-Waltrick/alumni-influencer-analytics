<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Alumni of the Day | Alumni Bidding</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <style>
    body { background: #f8f9fa; }
    .card { border: none; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
    .profile-img { width: 120px; height: 120px; object-fit: cover; border-radius: 50%; background: #dee2e6; }
    .section-title { font-size: .85rem; text-transform: uppercase; letter-spacing: .05em; color: #6c757d; font-weight: 600; }
  </style>
</head>
<body>

<!-- Simple public header — no login required -->
<nav class="navbar navbar-dark bg-dark mb-4">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/alumni-of-the-day">Alumni Bidding</a>
    <a href="/login" class="btn btn-outline-light btn-sm">Alumni Login</a>
  </div>
</nav>

<div class="container pb-5" style="max-width:760px">

  <div class="text-center mb-4">
    <h2 class="fw-bold">Alumni of the Day</h2>
    <p class="text-muted" id="featuredDate">Loading...</p>
  </div>

  <!-- Loading state -->
  <div id="loadingState" class="text-center py-5">
    <div class="spinner-border text-secondary" role="status"></div>
  </div>

  <!-- No winner yet -->
  <div id="noWinnerState" class="card p-5 text-center d-none">
    <h4 class="fw-bold mb-2">No featured alumnus yet today</h4>
    <p class="text-muted mb-0">Today's winner is selected at midnight UTC. Check back soon!</p>
  </div>

  <!-- Winner profile -->
  <div id="profileState" class="d-none">

    <div class="card p-4 mb-4">
      <div class="d-flex align-items-center gap-4">
        <img id="profileImg" src="" class="profile-img"
             onerror="this.src='https://ui-avatars.com/api/?size=120&background=6c757d&color=fff&name=Alumni'" />
        <div>
          <h3 class="fw-bold mb-1" id="profileName"></h3>
          <p class="text-muted mb-2" id="profileBio"></p>
          <a id="profileLinkedIn" href="#" target="_blank" class="btn btn-sm btn-outline-primary d-none">
            View LinkedIn Profile
          </a>
        </div>
      </div>
    </div>

    <!-- Degrees -->
    <div class="card p-4 mb-3" id="degreesCard">
      <p class="section-title mb-2">Degrees</p>
      <div id="degreesList"></div>
    </div>

    <!-- Certifications -->
    <div class="card p-4 mb-3" id="certsCard">
      <p class="section-title mb-2">Certifications</p>
      <div id="certsList"></div>
    </div>

    <!-- Employment -->
    <div class="card p-4 mb-3" id="employmentCard">
      <p class="section-title mb-2">Employment</p>
      <div id="employmentList"></div>
    </div>

    <!-- Licences -->
    <div class="card p-4 mb-3" id="licencesCard">
      <p class="section-title mb-2">Licences</p>
      <div id="licencesList"></div>
    </div>

    <!-- Courses -->
    <div class="card p-4 mb-3" id="coursesCard">
      <p class="section-title mb-2">Courses</p>
      <div id="coursesList"></div>
    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
function renderItems(containerId, cardId, items, renderFn) {
  const card = document.getElementById(cardId);
  if (!items || items.length === 0) { card.style.display = 'none'; return; }
  document.getElementById(containerId).innerHTML = items.map(renderFn).join('');
}

async function loadAlumni() {
  try {
    const res = await fetch('/api/public/alumni-of-the-day/public');
    const data = await res.json();

    document.getElementById('loadingState').classList.add('d-none');

    if (res.status === 404) {
      document.getElementById('noWinnerState').classList.remove('d-none');
      return;
    }

    const p = data.profile;
    document.getElementById('featuredDate').textContent = 'Featured on ' + data.featuredDate;
    document.getElementById('profileName').textContent = p.firstName + ' ' + p.lastName;
    document.getElementById('profileBio').textContent = p.bio || '';

    if (p.profileImagePath) {
      document.getElementById('profileImg').src = p.profileImagePath;
    }

    if (p.linkedInUrl) {
      const link = document.getElementById('profileLinkedIn');
      link.href = p.linkedInUrl;
      link.classList.remove('d-none');
    }

    renderItems('degreesList', 'degreesCard', p.degrees, d =>
      `<div class="border rounded p-2 mb-2 small"><strong>${d.title}</strong> — ${d.institution || ''}
       ${d.url ? `<a href="${d.url}" target="_blank" class="ms-2">View</a>` : ''}</div>`);

    renderItems('certsList', 'certsCard', p.certifications, c =>
      `<div class="border rounded p-2 mb-2 small"><strong>${c.title}</strong> ${c.issuingBody ? '— ' + c.issuingBody : ''}
       ${c.url ? `<a href="${c.url}" target="_blank" class="ms-2">View</a>` : ''}</div>`);

    renderItems('employmentList', 'employmentCard', p.employment, e =>
      `<div class="border rounded p-2 mb-2 small"><strong>${e.jobTitle}</strong> at ${e.company}
       <span class="text-muted ms-2">${e.startDate ? new Date(e.startDate).getFullYear() : ''} — ${e.endDate ? new Date(e.endDate).getFullYear() : 'Present'}</span></div>`);

    renderItems('licencesList', 'licencesCard', p.licences, l =>
      `<div class="border rounded p-2 mb-2 small"><strong>${l.title}</strong> ${l.awardingBody ? '— ' + l.awardingBody : ''}
       ${l.url ? `<a href="${l.url}" target="_blank" class="ms-2">View</a>` : ''}</div>`);

    renderItems('coursesList', 'coursesCard', p.courses, c =>
      `<div class="border rounded p-2 mb-2 small"><strong>${c.title}</strong> ${c.provider ? '— ' + c.provider : ''}
       ${c.url ? `<a href="${c.url}" target="_blank" class="ms-2">View</a>` : ''}</div>`);

    document.getElementById('profileState').classList.remove('d-none');

  } catch (err) {
    document.getElementById('loadingState').classList.add('d-none');
    document.getElementById('noWinnerState').classList.remove('d-none');
  }
}

loadAlumni();
</script>
</body>
</html>
