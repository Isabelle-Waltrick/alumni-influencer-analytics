<%- include('../partials/head', { title: 'Forgot Password' }) %>
<div class="container" style="max-width:460px;margin-top:80px">
  <div class="card p-4">
    <h4 class="mb-1 fw-bold">Reset your password</h4>
    <p class="text-muted small mb-4">Enter your email and we'll send a reset link if the account exists.</p>

    <div id="alert" class="alert d-none"></div>

    <form id="forgotForm">
      <div class="mb-3">
        <label class="form-label">Email address</label>
        <input type="email" class="form-control" id="email" required />
      </div>
      <button type="submit" class="btn btn-dark w-100" id="submitBtn">Send reset link</button>
    </form>

    <p class="mt-3 text-center small"><a href="/login">Back to login</a></p>
  </div>
</div>

<script>
  document.getElementById('forgotForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submitBtn');
    btn.disabled = true;
    btn.textContent = 'Sending...';

    const { data } = await api.post('/api/auth/forgot-password', {
      email: document.getElementById('email').value,
    });
    const alertEl = document.getElementById('alert');
    alertEl.classList.remove('d-none', 'alert-success', 'alert-danger');
    alertEl.classList.add('alert-success');
    // always show the same message — matches anti-enumeration on the server
    alertEl.textContent = data.message;
    btn.textContent = 'Sent';
  });
</script>
<%- include('../partials/foot') %>
