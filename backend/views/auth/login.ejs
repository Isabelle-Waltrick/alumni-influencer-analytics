<%- include('../partials/head', { title: 'Login' }) %>
<div class="container" style="max-width:460px;margin-top:80px">
  <div class="card p-4">
    <h4 class="mb-4 fw-bold">Sign in</h4>

    <div id="alert" class="alert d-none"></div>

    <form id="loginForm">
      <div class="mb-3">
        <label class="form-label">Email address</label>
        <input type="email" class="form-control" id="email" required />
      </div>
      <div class="mb-3">
        <label class="form-label">Password</label>
        <input type="password" class="form-control" id="password" required />
      </div>
      <button type="submit" class="btn btn-dark w-100" id="submitBtn">Sign in</button>
    </form>

    <div class="mt-3 d-flex justify-content-between small">
      <a href="/register">Create account</a>
      <a href="/forgot-password">Forgot password?</a>
    </div>
  </div>
</div>

<script>
  document.getElementById('loginForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submitBtn');
    btn.disabled = true;
    btn.textContent = 'Signing in...';

    const { status, data } = await api.post('/api/auth/login', {
      email: document.getElementById('email').value,
      password: document.getElementById('password').value,
    });

    if (status === 200) {
      window.location.href = '/profile';
    } else {
      const alertEl = document.getElementById('alert');
      alertEl.classList.remove('d-none', 'alert-danger');
      alertEl.classList.add('alert-danger');
      alertEl.textContent = data.errors?.[0]?.msg || data.message || 'Login failed.';
      btn.disabled = false;
      btn.textContent = 'Sign in';
    }
  });
</script>
<%- include('../partials/foot') %>
