<%- include('../partials/head', { title: 'Reset Password' }) %>
<div class="container" style="max-width:460px;margin-top:80px">
  <div class="card p-4">
    <h4 class="mb-4 fw-bold">Choose a new password</h4>

    <div id="alert" class="alert d-none"></div>

    <form id="resetForm">
      <div class="mb-3">
        <label class="form-label">New password</label>
        <input type="password" class="form-control" id="password" required />
        <div class="form-text">Min 8 chars, 1 uppercase, 1 number, 1 special character.</div>
      </div>
      <div class="mb-3">
        <label class="form-label">Confirm password</label>
        <input type="password" class="form-control" id="confirm" required />
      </div>
      <button type="submit" class="btn btn-dark w-100" id="submitBtn">Update password</button>
    </form>
  </div>
</div>

<script>
  document.getElementById('resetForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const alertEl = document.getElementById('alert');
    const pw = document.getElementById('password').value;
    const confirm = document.getElementById('confirm').value;

    alertEl.classList.remove('d-none', 'alert-success', 'alert-danger');

    if (pw !== confirm) {
      alertEl.classList.add('alert-danger');
      alertEl.textContent = 'Passwords do not match.';
      return;
    }

    const btn = document.getElementById('submitBtn');
    btn.disabled = true;
    btn.textContent = 'Updating...';

    const { status, data } = await api.post('/api/auth/reset-password/<%= token %>', { password: pw });

    if (status === 200) {
      alertEl.classList.add('alert-success');
      alertEl.textContent = data.message + ' Redirecting to login...';
      setTimeout(() => window.location.href = '/login', 2500);
    } else {
      alertEl.classList.add('alert-danger');
      alertEl.textContent = data.errors?.[0]?.msg || data.message || 'Reset failed.';
      btn.disabled = false;
      btn.textContent = 'Update password';
    }
  });
</script>
<%- include('../partials/foot') %>
