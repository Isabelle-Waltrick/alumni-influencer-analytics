<%- include('../partials/head', { title: 'Register' }) %>
<div class="container" style="max-width:460px;margin-top:80px">
  <div class="card p-4">
    <h4 class="mb-4 fw-bold">Create an account</h4>

    <div id="alert" class="alert d-none"></div>

    <form id="registerForm" onsubmit="return false">
      <div class="mb-3">
        <label class="form-label">Email address</label>
        <input type="email" class="form-control" id="email" required />
      </div>
      <div class="mb-3">
        <label class="form-label">Password</label>
        <input type="password" class="form-control" id="password" required />
        <div class="form-text">Min 8 chars, 1 uppercase, 1 number, 1 special character.</div>
      </div>
      <div class="mb-3">
        <label class="form-label">Account type</label>
        <select class="form-select" id="role">
          <option value="alumnus">Alumnus - bid for featured slots</option>
          <option value="developer">Developer - access public API</option>
        </select>
      </div>
      <button type="submit" class="btn btn-dark w-100" id="submitBtn">Register</button>
    </form>

    <p class="mt-3 text-center small">Already have an account? <a href="/login">Log in</a></p>
  </div>
</div>

<script>
  document.getElementById('registerForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submitBtn');
    const alertEl = document.getElementById('alert');
    btn.disabled = true;
    btn.textContent = 'Registering...';

    try {
      const { status, data } = await api.post('/api/auth/register', {
        email: document.getElementById('email').value,
        password: document.getElementById('password').value,
        role: document.getElementById('role').value,
      });
      alertEl.classList.remove('d-none', 'alert-success', 'alert-danger');

      if (status === 201) {
        alertEl.classList.add('alert-success');
        alertEl.textContent = data.message;
        document.getElementById('registerForm').reset();
      } else {
        alertEl.classList.add('alert-danger');
        alertEl.textContent = data.errors?.[0]?.msg || data.message || 'Registration failed.';
        btn.disabled = false;
        btn.textContent = 'Register';
      }
    } catch (err) {
      alertEl.classList.remove('d-none', 'alert-success', 'alert-danger');
      alertEl.classList.add('alert-danger');
      alertEl.textContent = 'Network error. Is the server running?';
      btn.disabled = false;
      btn.textContent = 'Register';
    }
  });
</script>
<%- include('../partials/foot') %>
